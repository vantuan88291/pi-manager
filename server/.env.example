# Pi Manager - Backend Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3001

# CORS - Allowed origins (comma-separated)
# Add your Cloudflare tunnel URL + localhost for development
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3001

# Telegram Bot Configuration (required for Telegram auth)
# Get from @BotFather in Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Admin Telegram User ID (for whitelist)
# Your Telegram user ID (can get from @userinfobot)
ADMIN_TELEGRAM_ID=your-telegram-id

# Note: User whitelist is stored in server/src/config/whitelist.json
# Add allowed Telegram user IDs there (JSON array format)
