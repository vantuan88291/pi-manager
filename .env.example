# Pi Manager - Frontend Environment Variables
# Copy this file to .env and fill in your values

# Socket URL - detected at runtime via window.location.origin
# This is automatically set by start-with-tunnel.sh
# Leave as-is or set to your tunnel URL for development
EXPO_PUBLIC_SOCKET_URL=__TUNNEL_URL__

# Telegram Bot Token (optional - for Telegram Mini App integration)
# Get from @BotFather in Telegram
EXPO_PUBLIC_TELEGRAM_BOT_TOKEN=your-bot-token-here

# Admin Telegram User ID (for whitelist)
# Your Telegram user ID (can get from @userinfobot)
ADMIN_TELEGRAM_ID=your-telegram-id
