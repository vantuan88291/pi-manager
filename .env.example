# Pi Manager - Frontend Environment Variables
# Copy this file to .env and fill in your values

# Socket / API base URL (optional).
# - Expo web (yarn web): set to http://localhost:3001 so Socket.IO hits the Node server (not Metro :8081).
# - Served from server/public or tunnel: omit or leave unset → uses window.location.origin (same host).
EXPO_PUBLIC_SOCKET_URL=http://localhost:3001

# Telegram Bot Token (optional - for Telegram Mini App integration)
# Get from @BotFather in Telegram
EXPO_PUBLIC_TELEGRAM_BOT_TOKEN=your-bot-token-here

# Admin Telegram User ID (for whitelist)
# Your Telegram user ID (can get from @userinfobot)
ADMIN_TELEGRAM_ID=your-telegram-id
# Set to true to open the app in a normal browser (no Telegram Mini App).
# Socket connects without initData; backend must allow it (e.g. server with empty TELEGRAM_BOT_TOKEN).
# Do not enable on production builds exposed to the internet.
EXPO_PUBLIC_DEBUG=false

# Node server DEBUG (scripts/start-with-tunnel.sh writes this to server/.env).
# true = Socket allows browser without Telegram (only for local/dev). Default when omitted: false.
# SERVER_DEBUG=false
# Or use the same key (not EXPO_PUBLIC_*):
# DEBUG=false
